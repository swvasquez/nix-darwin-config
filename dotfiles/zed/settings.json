{
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "basher": true,
    "make": true,
    "nix": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "helix_mode": true,
  "languages": {
    "Markdown": {
      "preferred_line_length": 80,
      "soft_wrap": "preferred_line_length"
    }
  },
  "show_wrap_guides": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "title_bar": {
    "show_sign_in": false
  },
  "wrap_guides": [
    80,
    100
  ]
}
